# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth - production replaces the demo session route with Better Auth Google OAuth.
BETTER_AUTH_SECRET="replace-with-at-least-32-random-characters"
BETTER_AUTH_URL="http://localhost:3000"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Database - required when persistent tasks, users, ledgers, and admin audit are connected.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Video model provider - MVP provider abstraction targets EvoLink Seedance first.
MODEL_PROVIDER="evolink"
EVOLINK_API_KEY=""
EVOLINK_API_URL=""
SEEDANCE_MODEL="seedance-1.0-pro-fast"

# Payment - production webhook is the source of truth for unlocks and subscriptions.
CREEM_API_KEY=""
CREEM_WEBHOOK_SECRET=""
CREEM_SIMULATE="true"

# Storage - use Cloudflare R2 or another S3-compatible store for uploads and generated videos.
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET=""
S3_PUBLIC_BASE_URL=""

# Cron
CRON_SECRET=""

# Abuse and support
ABUSE_CONTACT_EMAIL="abuse@dancegen.ai"
SUPPORT_EMAIL="support@dancegen.ai"
