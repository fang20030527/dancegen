# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Auth - use the canonical public origin in production, for example https://www.danceclip.org.
BETTER_AUTH_SECRET="replace-with-at-least-32-random-characters"
BETTER_AUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Database - required when persistent tasks, users, ledgers, and admin audit are connected.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Video model providers - Viggle is the default public generator; EvoLink remains for the member Seedance model.
MODEL_PROVIDER="viggle"
VIGGLE_API_KEY=""
VIGGLE_API_URL="https://apis.viggle.ai"
VIGGLE_MODEL="V4_Preview"
EVOLINK_API_KEY=""
EVOLINK_API_URL="https://api.evolink.ai"
EVOLINK_FILES_API_URL="https://files-api.evolink.ai"
SEEDANCE_ADVANCED_MODEL="seedance-2.0-mini-reference-to-video"

# Payment - use Creem Test Mode during development.
CREEM_API_KEY=""
CREEM_BASE_URL="https://test-api.creem.io"
CREEM_WEBHOOK_SECRET=""
CREEM_SIMULATE="false"
# Creem product IDs used by the checkout API.
CREEM_STARTER_MONTHLY_PRODUCT_ID=""
CREEM_CREATOR_MONTHLY_PRODUCT_ID=""
CREEM_PRO_MONTHLY_PRODUCT_ID=""
CREEM_STARTER_ANNUAL_PRODUCT_ID=""
CREEM_CREATOR_ANNUAL_PRODUCT_ID=""
CREEM_PRO_ANNUAL_PRODUCT_ID=""
# Optional legacy one-time unlock product. Leave empty when only subscription plans are sold.
CREEM_SINGLE_UNLOCK_PRODUCT_ID=""

# Storage - use Cloudflare R2 or another S3-compatible store for uploads and generated videos.
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET=""
S3_PUBLIC_BASE_URL=""

# Cron
CRON_SECRET=""

# Abuse and support
ABUSE_CONTACT_EMAIL="abuse@danceclip.org"
WAITLIST_EMAIL="waitlist@danceclip.org"

# Contact email - Resend sends contact form messages to the recipient below.
RESEND_API_KEY=""
NEXT_PUBLIC_CONTACT_EMAIL="feedback@danceclip.org.com"
RESEND_FROM_EMAIL="DanceClip AI <feedback@danceclip.org.com>"
CONTACT_RECIPIENT_EMAIL="zhenyufang162@gmail.com"

# Crisp chat widget
NEXT_PUBLIC_CRISP_WEBSITE_ID=""
